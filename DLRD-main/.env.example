# Data-Lineage and Retro-Documentation (local) — example environment configuration.
#
# Copy this file to ".env" (which is gitignored) OR simply enter these values
# in the browser config screen on first run. Either way they configure the
# ONLY network destination this app is ever allowed to reach: your LLMAAS.
#
# The api key is a SECRET: it is never committed, never logged, and never
# written into the generated knowledge-graph.json.

# Base URL of your OpenAI-compatible LLMAAS endpoint.
# Keep any trailing /v1 exactly as your provider gives it — it is not guessed.
UA_API_BASE=https://your-llmaas-host/v1

# Your API key (secret).
UA_API_KEY=replace-me

# Model name as exposed by your endpoint.
UA_MODEL=your-model-name

# Path to a CA-certificate bundle (PEM) used to verify the LLMAAS TLS
# certificate when it is signed by an internal/private CA. Leave empty to use
# the default public CA store. This only selects which CA validates the
# certificate — TLS verification is ALWAYS on and the egress host stays pinned.
# (Equivalent to your llmconfig.py LLMAAS_VERIFY path. Reference by path only;
# never commit the bundle itself.)
UA_CA_CERT=

# Output language for the LLM-generated content (summaries, tours). One of:
#   en (English), fr (French)   — default: en
# The dashboard's own UI chrome is always English regardless of this value.
UA_LANGUAGE=en

# Some models (e.g. gemma) reject "system" messages. Set to false to fold the
# system prompt into the first user message. Default: true.
UA_SUPPORTS_SYSTEM_MESSAGE=true

# Optional server tuning:
# UA_PORT=8765
# UA_DEBUG=false
